# ==============================================================
# WhatsApp AI Logistics Chatbot — Environment Configuration
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file to version control.
# ==============================================================

# ---- Twilio (WhatsApp messaging channel) ----
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio Sandbox default number, replace with your approved WhatsApp sender in production
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---- Anthropic Claude (conversation + information extraction engine) ----
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# ---- OpenAI Whisper (speech-to-text for WhatsApp voice notes) ----
OPENAI_API_KEY=your_openai_api_key
WHISPER_MODEL=whisper-1

# ---- YellowBIRD Logistics API ----
YELLOWBIRD_API_BASE_URL=https://sandbox-api.yellowbird.ug/v1
YELLOWBIRD_API_KEY=your_yellowbird_api_key
YELLOWBIRD_MERCHANT_ID=your_merchant_id
# Shared secret used to validate inbound YellowBIRD webhook HMAC signatures
YELLOWBIRD_WEBHOOK_SECRET=your_webhook_shared_secret

# ---- App settings ----
DATABASE_PATH=conversations.db
SESSION_TIMEOUT_MINUTES=60
PORT=5000
FLASK_DEBUG=false
